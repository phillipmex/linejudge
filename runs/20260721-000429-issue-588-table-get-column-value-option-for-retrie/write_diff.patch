@@ -2234,14 +2238,24 @@ class Table(Queryable):
         "Does this table use ``rowid`` for its primary key (no other primary keys are specified)?"
         return not any(column for column in self.columns if column.is_pk)
 
-    def get(self, pk_values: Union[list, tuple, str, int]) -> dict:
+    def get(
+        self, pk_values: Optional[Union[list, tuple, str, int]] = None, **kwargs
+    ) -> dict:
         """
-        Return row (as dictionary) for the specified primary key.
+        Return row (as dictionary) for the specified primary key, or for the
+        column values passed as keyword arguments.
 
         Raises ``sqlite_utils.db.NotFoundError`` if a matching row cannot be found.
 
         :param pk_values: A single value, or a tuple of values for tables that have a compound primary key
+        :param kwargs: Alternative lookup, as ``column=value`` pairs - useful for columns with a unique index
         """
+        if kwargs:
+            if pk_values is not None:
+                raise TypeError(
+                    "Cannot use both pk_values and keyword arguments with .get()"
+                )
+            return self._get_by_columns(kwargs)
         if not isinstance(pk_values, (list, tuple)):
             pk_values = [pk_values]
         pks = self.pks
@@ -2262,6 +2276,26 @@ class Table(Queryable):
         except IndexError:
             raise NotFoundError
 
+    def _get_by_columns(self, lookup: Dict[str, Any]) -> dict:
+        # Used by .get(column=value) - validates columns then returns the single
+        # matching row, or raises NotFoundError if there isn't exactly one.
+        bad_columns = [key for key in lookup if key not in self.columns_dict]
+        if bad_columns:
+            raise InvalidColumns(
+                "Invalid columns {} for table with columns {}".format(
+                    sorted(bad_columns), list(self.columns_dict.keys())
+                )
+            )
+        wheres = ["{} = ?".format(quote_identifier(key)) for key in lookup]
+        rows = list(
+            self.rows_where(" and ".join(wheres), list(lookup.values()), limit=2)
+        )
+        if not rows:
+            raise NotFoundError
+        if len(rows) > 1:
+            raise MultipleResults("More than one row matched {}".format(lookup))
+        return rows[0]
+
