diff --git a/tests/test_get.py b/tests/test_get.py
index 63c4a2e..bd787ec 100644
--- a/tests/test_get.py
+++ b/tests/test_get.py
@@ -1,5 +1,5 @@
 import pytest
-from sqlite_utils.db import NotFoundError
+from sqlite_utils.db import InvalidColumns, MultipleResults, NotFoundError
 
 
 def test_get_rowid(fresh_db):
@@ -29,3 +29,56 @@ def test_get_not_found(argument, expected_msg, fresh_db):
         fresh_db["dogs"].get(argument)
     if expected_msg is not None:
         assert expected_msg == excinfo.value.args[0]
+
+
+@pytest.fixture
+def collections_db(fresh_db):
+    collections = fresh_db["collections"]
+    collections.insert_all(
+        [
+            {"id": 1, "name": "entries", "model": "ada"},
+            {"id": 2, "name": "photos", "model": "clip"},
+        ],
+        pk="id",
+    )
+    collections.create_index(["name"], unique=True)
+    return fresh_db
+
+
+def test_get_by_column(collections_db):
+    assert collections_db["collections"].get(name="entries") == {
+        "id": 1,
+        "name": "entries",
+        "model": "ada",
+    }
+
+
+def test_get_by_multiple_columns(collections_db):
+    assert collections_db["collections"].get(name="photos", model="clip") == {
+        "id": 2,
+        "name": "photos",
+        "model": "clip",
+    }
+
+
+def test_get_by_column_not_found(collections_db):
+    with pytest.raises(NotFoundError):
+        collections_db["collections"].get(name="nope")
+
+
+def test_get_by_invalid_column(collections_db):
+    with pytest.raises(InvalidColumns):
+        collections_db["collections"].get(nope="entries")
+
+
+def test_get_by_column_multiple_results(fresh_db):
+    fresh_db["dogs"].insert_all(
+        [{"id": 1, "name": "Cleo"}, {"id": 2, "name": "Cleo"}], pk="id"
+    )
+    with pytest.raises(MultipleResults):
+        fresh_db["dogs"].get(name="Cleo")
+
+
+def test_get_pk_and_kwargs_error(collections_db):
+    with pytest.raises(TypeError):
+        collections_db["collections"].get(1, name="entries")
