@@ -1170,6 +1171,23 @@ def test_vacuum(fresh_db):
     fresh_db.vacuum()
 
 
+@pytest.mark.parametrize("begin", (True, False))
+def test_vacuum_inside_transaction_raises(fresh_db, begin):
+    fresh_db["data"].insert({"foo": "foo", "bar": "bar"})
+    if begin:
+        fresh_db.begin()
+        with pytest.raises(TransactionError) as ex:
+            fresh_db.vacuum()
+        fresh_db.rollback()
+    else:
+        with fresh_db.atomic():
+            with pytest.raises(TransactionError) as ex:
+                fresh_db.vacuum()
+    assert "cannot VACUUM from within a transaction" in str(ex.value)
+    # The transaction was left intact, and vacuum() works once it is over
+    fresh_db.vacuum()
+
+
